end

-- ======================== CRAB AUTOMATIONS ========================
local function getCost(amount, crabPower, buyTier)
    local base = crabPower <= 0 and 5 or math.floor(5 + 2.1 * crabPower ^ 0.875)
    return base * amount * (3 ^ (buyTier - 1))
end
local AMOUNTS = {100, 25, 5, 1}

local function tryBuyWithMirror()
    local cash = MirrorClient.get("cash") or 0
    local crabPower = MirrorClient.get("crabPower") or 0
    local buyTier = MirrorClient.get("buyTier") or 1
    for _, amount in ipairs(AMOUNTS) do
        if cash >= getCost(amount, crabPower, buyTier) then
            pcall(function() BuyCrab:FireServer(amount) end)
            break
        end
    end
end

local function tryBuyFallback()
    local cashObj = LocalPlayer:FindFirstChild("leaderstats")
    if not cashObj then return end
    cashObj = cashObj:FindFirstChild("Cash")
    if not cashObj then return end
    local currentCash = tonumber(string.gsub(tostring(cashObj.Value), "[^%d%.]", ""))
    if not currentCash then return end
    local plot = getPlot()
    if not plot then return end
    for modelName, amount in pairs({Buy100=100, Buy25=25, Buy5=5, Buy1=1}) do
        local model = plot:FindFirstChild(modelName)
        if model and model:IsA("Model") and model:GetAttribute("Purchased") ~= true then
            local costLabel = model:FindFirstChild("Label")
            if costLabel then costLabel = costLabel:FindFirstChild("Cost") end
            if costLabel and costLabel:IsA("TextLabel") then
                local cost = tonumber(string.gsub(costLabel.Text, "[^%d%.]", ""))
                if cost and currentCash >= cost then
                    pcall(function() BuyCrab:FireServer(amount) end)
                    break
                end
            end
        end
    end
end

local function tryMerge()
    if not MirrorClient then return end
    local crabTiers = MirrorClient.get("crabTiers") or {}
    local counts = {}
    for _, tier in ipairs(crabTiers) do
        counts[tier] = (counts[tier] or 0) + 1
        if counts[tier] >= 3 then
            pcall(function() MergeCrab:FireServer() end)
            return
        end
    end
end

local function tryDepositShells()
    if not MirrorClient then return end
    if (MirrorClient.get("heldShells") or 0) > 0 then
        pcall(function() DepositShells:FireServer() end)
    end
end

local function tryCollectCash()
    if not MirrorClient then return end
    if (MirrorClient.get("pendingCash") or 0) > 0 then
        pcall(function() CollectCash:FireServer() end)
    end
end

local function tryUpgradeProcessing()
    if not MirrorClient or not Formulas then return end
    local level = MirrorClient.get("processingLevel") or 1
    local cash = MirrorClient.get("cash") or 0
    local cost100 = 0
    for lvl = level, level + 99 do cost100 = cost100 + Formulas.GetProcessingUpgradeCost(lvl) end
    if cash >= cost100 then
        pcall(function() UpgradeProcessing:FireServer(100) end)
    elseif cash >= Formulas.GetProcessingUpgradeCost(level) then
        pcall(function() UpgradeProcessing:FireServer(1) end)
    end
end

-- ======================== AUTO UPGRADE BUY TIER ========================
local function tryUpgradeBuyTier()
    if MirrorClient and CrabTiers then
        local buyTier = MirrorClient.get("buyTier") or 1
        local crabPower = MirrorClient.get("crabPower") or 0
        local cash = MirrorClient.get("cash") or 0
        local nextTier = buyTier + 1
        if nextTier <= CrabTiers.BUY_TIER_CAP then
            local data = CrabTiers.BUY_TIER_UPGRADES[nextTier]
            if data and crabPower >= data.gate and cash >= data.cost then
                pcall(function() UpgradeBuyTier:FireServer() end)
                return
            end
        end
    end
    local plot = getPlot()
    if not plot then return end
    local upgradeModel = plot:FindFirstChild("UpgradeBaseTier")
    if upgradeModel and upgradeModel:IsA("Model") then
        local pressPart = upgradeModel:FindFirstChild("Press")
        if pressPart and pressPart:IsA("BasePart") and pressPart.Color == Color3.fromRGB(255, 161, 29) then
            pcall(function() UpgradeBuyTier:FireServer() end)
        end
    end
end

