local function magnetTickSingle()
    if #shellCache == 0 then return end
    if shellIndex > #shellCache then shellIndex = 1 end
    local shell = shellCache[shellIndex]
    shellIndex = shellIndex + 1
    if shellIndex > #shellCache then shellIndex = 1 end
    if not shell or not shell.Parent then return end

    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    pcall(function()
        shell.Anchored = false
        shell.CanCollide = false
        shell.Transparency = 1
        shell.CFrame = hrp.CFrame + Vector3.new(0, 2, 0)
    end)
    pcall(function()
        firetouchinterest(hrp, shell, 0)
        firetouchinterest(hrp, shell, 1)
    end)
end

