    end
end

-- ======================== SHELL MAGNET (works again) ========================
local function updateShellCache()
    local parts = {}
    -- Hidden shells (nil parent)
    local success, instances = pcall(function() return getnilinstances() end)
    if success and instances then
        for _, obj in ipairs(instances) do
            if (obj:IsA("MeshPart") and tonumber(obj.Name)) or (obj:IsA("BasePart") and obj.Name == "carryPosition") then
                table.insert(parts, obj)
            end
        end
    end
    -- Workspace shells (visible)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if (obj:IsA("MeshPart") and tonumber(obj.Name)) or (obj:IsA("BasePart") and obj.Name == "carryPosition") then
            if not table.find(parts, obj) then table.insert(parts, obj) end
        end
    end
    shellCache = parts
end

local function magnetTick()
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, shell in ipairs(shellCache) do
        if shell and shell.Parent then
            pcall(function()
                shell.Anchored = false
                shell.CanCollide = false
                shell.CFrame = hrp.CFrame + Vector3.new(0, 2, 0)
            end)
            pcall(function()
                firetouchinterest(hrp, shell, 0)
                firetouchinterest(hrp, shell, 1)
            end)
        end
    end
end

-- ======================== EGG AUTOMATIONS (event‑based, no scans) ========================
-- Initial fill + real‑time tracking
eggCache = {}
for _, obj in ipairs(workspace:GetDescendants()) do
    if obj:IsA("Part") and obj.Name == "EggSphere" and obj.Parent then
        table.insert(eggCache, obj)
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("Part") and obj.Name == "EggSphere" then
        table.insert(eggCache, obj)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("Part") and obj.Name == "EggSphere" then
        local idx = table.find(eggCache, obj)
        if idx then table.remove(eggCache, idx) end
    end
end)

local function collectEggs()
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if #eggCache == 0 then return end
    local closest, minDist = nil, math.huge
    for _, egg in ipairs(eggCache) do
        if egg and egg.Parent then
            local dist = (egg.Position - hrp.Position).Magnitude
            if dist < minDist then
                minDist = dist
                closest = egg
            end
        end
    end
    if closest then
        pcall(function()
            firetouchinterest(hrp, closest, 0)
            firetouchinterest(hrp, closest, 1)
        end)
    end
end

local function tryHatchEgg()
    if not MirrorClient then return end
    local heldType = MirrorClient.get("heldEggType") or 0
    if heldType == 0 then return end
    local crabPower = MirrorClient.get("crabPower") or 0
    local base = crabPower <= 0 and 5 or math.floor(5 + 2.1 * crabPower ^ 0.875)
    local cost = EggConfig and EggConfig.getEggCost(heldType, base) or 1e9
    local cash = MirrorClient.get("cash") or 0
    if cash >= cost then
        pcall(function() OpenEgg:FireServer() end)
    end
end

local function tryIncubate()
    if not MirrorClient then return end
    if (MirrorClient.get("heldEggType") or 0) > 0 and (MirrorClient.get("incubatingEggType") or 0) == 0 then
        pcall(function() IncubateEgg:FireServer() end)
    end
end

local function tryQuickIncubate()
    if not MirrorClient then return end
    if (MirrorClient.get("heldEggType") or 0) > 0 and (MirrorClient.get("quickIncEggType") or 0) == 0 then
        pcall(function() QuickIncubateEgg:FireServer() end)
    end
end

local function tryClaimIncubators()
    if not MirrorClient then return end
    local incType = MirrorClient.get("incubatingEggType") or 0
    local incStart = MirrorClient.get("incubateStartTime") or 0
    if incType > 0 and os.time() - incStart >= INCUBATE_DURATION then
        pcall(function() ClaimIncubator:FireServer() end)
    end
    local quickType = MirrorClient.get("quickIncEggType") or 0
    local quickStart = MirrorClient.get("quickIncStartTime") or 0
    if quickType > 0 and os.time() - quickStart >= QUICK_DURATION then
        pcall(function() ClaimQuickIncubator:FireServer() end)
    end
end

