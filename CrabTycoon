end

local function tryCollectCash()
    if not MirrorClient then return end
    if (MirrorClient.get("pendingCash") or 0) > 0 then
        pcall(function() CollectCash:FireServer() end)
    end
end

local function tryUpgradeProcessing()
    if not MirrorClient or not Formulas then return end
    local level = MirrorClient.get("processingLevel") or 1
    local cash = MirrorClient.get("cash") or 0
    local cost100 = 0
    for lvl = level, level + 99 do cost100 = cost100 + Formulas.GetProcessingUpgradeCost(lvl) end
    if cash >= cost100 then
        pcall(function() UpgradeProcessing:FireServer(100) end)
    elseif cash >= Formulas.GetProcessingUpgradeCost(level) then
        pcall(function() UpgradeProcessing:FireServer(1) end)
    end
end

-- ======================== AUTO UPGRADE BUY TIER ========================
local function tryUpgradeBuyTier()
    if MirrorClient and CrabTiers then
        local buyTier = MirrorClient.get("buyTier") or 1
        local crabPower = MirrorClient.get("crabPower") or 0
        local cash = MirrorClient.get("cash") or 0
        local nextTier = buyTier + 1
        if nextTier <= CrabTiers.BUY_TIER_CAP then
            local data = CrabTiers.BUY_TIER_UPGRADES[nextTier]
            if data and crabPower >= data.gate and cash >= data.cost then
                pcall(function() UpgradeBuyTier:FireServer() end)
                return
            end
        end
    end
    local plot = getPlot()
    if not plot then return end
    local upgradeModel = plot:FindFirstChild("UpgradeBaseTier")
    if upgradeModel and upgradeModel:IsA("Model") then
        local pressPart = upgradeModel:FindFirstChild("Press")
        if pressPart and pressPart:IsA("BasePart") and pressPart.Color == Color3.fromRGB(255, 161, 29) then
            pcall(function() UpgradeBuyTier:FireServer() end)
        end
    end
end

