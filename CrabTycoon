-- ======================== SAND COLLECTION (existing + remote queue) ========================
-- Function to collect an existing sandMound part via touch
local function collectExistingSandMound(part)
    if not part or not part.Parent then return end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local savedCF = root.CFrame
    root.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.05)   -- small delay to ensure the part is under the player
    pcall(function()
        firetouchinterest(root, part, 0)
        firetouchinterest(root, part, 1)
    end)
    root.CFrame = savedCF
end

-- Initial scan: collect all existing sandMound parts when the toggle is turned on
local function collectExistingSandMounds()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "sandMound" and obj.Parent then
            collectExistingSandMound(obj)
        end
    end
end

-- Remote queue for newly spawned mounds
if SpawnSand then
    SpawnSand.OnClientEvent:Connect(function(id, position, amount)
        if autoCollectSand then
            table.insert(sandQueue, {id = id, pos = position, amount = amount})
        end
    end)
end

if DespawnSand then
    DespawnSand.OnClientEvent:Connect(function(id)
        for i, mound in ipairs(sandQueue) do
            if mound.id == id then
                table.remove(sandQueue, i)
                break
            end
        end
    end)
end

local function processSandQueue()
    if processingQueue then return end
    processingQueue = true

    while #sandQueue > 0 do
        local mound = table.remove(sandQueue, 1)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then break end

        local savedCF = root.CFrame
        root.CFrame = CFrame.new(mound.pos) + Vector3.new(0, 3, 0)
        task.wait(0.1)
        pcall(function() CollectSand:FireServer(mound.id) end)
        root.CFrame = savedCF

        if #sandQueue > 0 then
            task.wait(0.1)
        end
    end

    processingQueue = false
end

