-- [[ Auto Farm EVERYTHING ]]
MainTab:CreateToggle({
    Name = "Auto Farm EVERYTHING",
    CurrentValue = false,
    Flag = "AutoZoneFarm",
    Callback = function(state)
        _G.AutoZoneFarm = state
        if state then
            task.spawn(function()
                local DELAY = 0.1
                local treeIndex = 0
                local currentZoneNum = nil
                local currentTrees = {}
                local zoneOrder = ZoneData.ZONE_ORDER

                local function getWorkspaceZoneName(idx)
                    return "Zone" .. tostring(idx)
                end

                local function cacheTrees(zoneName)
                    local folder = workspace.Zones[zoneName]:FindFirstChild("Trees")
                    local list = {}
                    if folder then
                        for _, child in ipairs(folder:GetChildren()) do
                            local part = child:FindFirstChildWhichIsA("BasePart", true)
                            if part then table.insert(list, part) end
                        end
                    end
                    return list
                end

                while _G.AutoZoneFarm do
                    pcall(function()
                        local logs = PlayerData.number("logs").read()
                        local zonesTable = PlayerData.table("zones").get()
                        local unlocks = ZoneState.readUnlocks(zonesTable)

                        for _, zoneId in ipairs(zoneOrder) do
                            if not ZoneData.isStarter(zoneId) and ZoneState.canPurchase(zoneId, unlocks, {logs = logs}) then
                                ZoneNetwork.purchaseZone(zoneId)
                                task.wait(0.3)
                                zonesTable = PlayerData.table("zones").get()
                                unlocks = ZoneState.readUnlocks(zonesTable)
                            end
                        end

                        local bestZoneNum = nil
                        for i = #zoneOrder, 1, -1 do
                            if ZoneState.isUnlocked(zoneOrder[i], unlocks) then
                                bestZoneNum = i
                                break
                            end
                        end
                        if not bestZoneNum then return end

                        if currentZoneNum ~= bestZoneNum then
                            local zoneName = getWorkspaceZoneName(bestZoneNum)
                            local tp = workspace.Zones[zoneName]:FindFirstChild("Teleport")
                            tp = tp and tp:FindFirstChild("TP")
                            if tp and tp:IsA("BasePart") then
                                local char = player.Character
                                local root = char and char:FindFirstChild("HumanoidRootPart")
                                if root then
                                    root.CFrame = tp.CFrame + Vector3.new(0, 5, 0)
                                end
                            end
                            currentTrees = cacheTrees(zoneName)
                            currentZoneNum = bestZoneNum
                        end

                        if currentZoneNum and #currentTrees == 0 then
                            currentTrees = cacheTrees(getWorkspaceZoneName(currentZoneNum))
                        end

                        if #currentTrees > 0 then
                            treeIndex = (treeIndex % #currentTrees) + 1
                            local target = currentTrees[treeIndex]
                            if target and target.Parent then
                                local char = player.Character
                                local root = char and char:FindFirstChild("HumanoidRootPart")
                                if root then
                                    root.CFrame = target.CFrame + Vector3.new(0, 5, 0)
                                end
                            end
                        end
                    end)
                    task.wait(DELAY)
                end
            end)
        end
    end
})

