    { id = "rainbow_honeycomb",  name = "Rainbow Honeycomb" },
    { id = "void_honeycomb",     name = "Void Honeycomb" },
}

local honeycombOptions = {"None"}
for _, v in ipairs(honeycombList) do
    table.insert(honeycombOptions, v.name)
end

local HoneycombDropdown = ItemsTab:CreateDropdown({
    Name = "Select Honeycombs to Hatch",
    Options = honeycombOptions,
    CurrentOption = {"None"},
    MultipleOptions = true,
    Flag = "SelectedHoneycomb",
    Callback = function(Options)
        local hasNone = false
        if Options then
            for _, opt in ipairs(Options) do
                if opt == "None" then hasNone = true break end
            end
        end
        if hasNone then
            HoneycombDropdown:Set({"None"})
        end
    end
})

ItemsTab:CreateButton({
    Name = "Refresh Honeycombs",
    Callback = function()
        local inv = PlayerData.table("items").read()
        local available = {"None"}
        for _, item in ipairs(honeycombList) do
            if inv[item.id] and inv[item.id] > 0 then
                table.insert(available, item.name)
            end
        end
        HoneycombDropdown:Refresh(available)
        HoneycombDropdown:Set({"None"})
    end
})

ItemsTab:CreateButton({
    Name = "Select All Honeycombs",
    Callback = function()
        local inv = PlayerData.table("items").read()
        local selected = {}
        for _, item in ipairs(honeycombList) do
            if inv[item.id] and inv[item.id] > 0 then
                table.insert(selected, item.name)
            end
        end
        if #selected == 0 then selected = {"None"} end
        HoneycombDropdown:Set(selected)
    end
})

ItemsTab:CreateToggle({
    Name = "Auto Hatch Honeycombs",
    CurrentValue = false,
    Flag = "AutoHatchToggle",
    Callback = function(state)
        _G.AutoHatch = state
        if state then
            task.spawn(function()
                while _G.AutoHatch do
                    pcall(function()
                        local selectedNames = HoneycombDropdown.CurrentOption
                        if not selectedNames or #selectedNames == 0 or selectedNames[1] == "None" then
                            task.wait(3)
                            break
                        end
                        local idsToHatch = {}
                        for _, name in ipairs(selectedNames) do
                            for _, item in ipairs(honeycombList) do
                                if item.name == name then
                                    table.insert(idsToHatch, item.id)
                                    break
                                end
                            end
                        end
                        for _, id in ipairs(idsToHatch) do
                            local inv = PlayerData.table("items").read()
                            if inv[id] and inv[id] > 0 then
                                BeeHatch.requestAllItems(id)
                            end
                        end
                    end)
                    task.wait(3)
                end
            end)
        end
    end
})

