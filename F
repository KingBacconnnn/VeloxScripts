    local rbFrame = player.PlayerGui.General.CurrencyHud:FindFirstChild("rebirthsCurrency")
    if rbFrame then
        rebirthsLabel = findTextLabel(rbFrame:FindFirstChild("Label"))
    end
end)

local function parseCurrency(str)
    if not str then return 0 end
    str = string.gsub(str, "%s", "")
    local num = tonumber(str)
    if num then return num end
    local number, suffix = string.match(str, "^([%.%d]+)([%a]?)$")
    if not number then return 0 end
    number = tonumber(number) or 0
    suffix = suffix and suffix:lower() or ""
    if suffix == "k" then return number * 1e3
    elseif suffix == "m" then return number * 1e6
    elseif suffix == "b" then return number * 1e9
    elseif suffix == "t" then return number * 1e12
    end
    return number
end

