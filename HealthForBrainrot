-- Auto Train Treadmill (best available)
task.spawn(function()
    local treadmillFolder = Workspace.Map.SpawnArea.TreadmillFolder
    local function getTreadmills()
        local list = {}
        for _, child in ipairs(treadmillFolder:GetChildren()) do
            if child:IsA("Model") then
                local req = 0
                local overhead = child:FindFirstChild("Overhead")
                if overhead then
                    local billboard = overhead:FindFirstChild("Attachment") and overhead.Attachment:FindFirstChild("Billboard")
                    if billboard then
                        local frame = billboard:FindFirstChild("Frame")
                        if frame then
                            local reqLabel = frame:FindFirstChild("Req")
                            if reqLabel and reqLabel:IsA("TextLabel") then
                                local num = tonumber(reqLabel.Text:match("%d+"))
                                if num then req = num end
                            end
                        end
                    end
                end
                table.insert(list, {model = child, req = req})
            end
        end
        return list
    end

    local function getCurrentRebirth()
        local ok, data = pcall(function() return ReplicatedStorage.Remotes.GetRebirthData:InvokeServer() end)
        if ok and data then return data.rebirthLevel or 0, data.currentLevel or 0, data.levelRequired or 1 end
        return 0, 0, 1
    end

    local function rebirthUntil(target)
        while true do
            local rb, lvl, reqLvl = getCurrentRebirth()
            if rb >= target then break end
            if lvl >= reqLvl then
                pcall(function() ReplicatedStorage.Remotes.RequestRebirth:FireServer() end)
                task.wait(3)
            else
                task.wait(5)
            end
        end
    end

    while true do
        if autoTrainTreadmill then
            pcall(function()
                local treadmills = getTreadmills()
                if #treadmills == 0 then task.wait(2); return end
                local rb = getCurrentRebirth()
                local best, bestReq = nil, -1
                for _, tm in ipairs(treadmills) do
                    if rb >= tm.req and tm.req > bestReq then
                        best = tm; bestReq = tm.req
                    end
                end
                if not best then
                    table.sort(treadmills, function(a,b) return a.req < b.req end)
                    best = treadmills[1]
                    rebirthUntil(best.req)
                    return
                end
                local part = nil
                for _, child in ipairs(best.model:GetDescendants()) do
                    if child:IsA("BasePart") then part = child; break end
                end
                if not part then part = best.model.PrimaryPart end
                if not part then task.wait(2); return end
                while autoTrainTreadmill and rb >= best.req do
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then root.CFrame = part.CFrame * CFrame.new(0, 3, 0) end
                    task.wait(0.1)
                    rb = getCurrentRebirth()
                end
            end)
        end
        task.wait(1)
    end
end)

