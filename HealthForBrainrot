-- Brainrot Autofarm (rarity + collect/deposit)
local function matchesFilter(brainrot)
    if not autoCollectBrainrots then return false end
    if next(selectedGroups) == nil then return false end
    local areaName = brainrot:GetAttribute("AreaName") or ""
    for groupName, _ in pairs(selectedGroups) do
        local valid = RARITY_GROUPS[groupName]
        if valid then
            for _, v in ipairs(valid) do
                if areaName == v then return true end
            end
        end
    end
    return false
end

local CollectionPart = Workspace:WaitForChild("Map"):WaitForChild("BrainrotCollectionPart")
local function depositBrainrot()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local origCF = hrp.CFrame
    hrp.CFrame = CollectionPart.CFrame * CFrame.new(0, 2, 0)
    RunService.Stepped:Wait()
    pcall(function() firetouchinterest(hrp, CollectionPart, 0) firetouchinterest(hrp, CollectionPart, 1) end)
    RunService.Stepped:Wait()
    hrp.CFrame = origCF
    return true
end

task.spawn(function()
    while true do
        if autoCollectBrainrots then
            pcall(function()
                local folder = Workspace:FindFirstChild("SpawnedBrainrots")
                if not folder then return end
                local brainrots = {}
                for _, obj in ipairs(folder:GetChildren()) do
                    if obj:IsA("Model") and obj:FindFirstChild("PickupHitbox") and matchesFilter(obj) then
                        table.insert(brainrots, obj)
                    end
                end
                local function priority(brainrot)
                    local area = brainrot:GetAttribute("AreaName") or ""
                    for i, groupName in ipairs(DISPLAY_ORDER) do
                        for _, v in ipairs(RARITY_GROUPS[groupName]) do
                            if area == v then return i end
                        end
                    end
                    return 999
                end
                table.sort(brainrots, function(a,b) return priority(a) < priority(b) end)
                for _, brainrot in ipairs(brainrots) do
                    if not autoCollectBrainrots then break end
                    if brainrot.Parent then
                        local pickupHitbox = brainrot:FindFirstChild("PickupHitbox")
                        if pickupHitbox then
                            local prompt = pickupHitbox:FindFirstChild("ProximityPrompt")
                            if prompt then
                                local char = LocalPlayer.Character
                                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    hrp.CFrame = pickupHitbox.CFrame + Vector3.new(0, 2, 0)
                                    task.wait(0.1)
                                    pcall(function() fireproximityprompt(prompt) end)
                                    task.wait(0.2)
                                    pcall(depositBrainrot)
                                    break
                                end
                            end
                        end
                    end
                end
            end)
        end
        task.wait(collectDelay)
    end
end)

