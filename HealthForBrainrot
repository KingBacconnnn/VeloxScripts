-- Auto Upgrade Brainrots (internal logic – not exposed in UI)
local SUFFIX = { K=1e3,M=1e6,B=1e9,T=1e12,Qa=1e15,Qi=1e18,Sx=1e21,Sp=1e24,Oc=1e27,No=1e30,Dc=1e33,Ud=1e36,Dd=1e39,Td=1e42,Qad=1e45,Qid=1e48 }
local function parsePrice(text)
    if not text then return nil end
    text = text:gsub("^%$",""):gsub("FREE","0")
    local num = tonumber(text:match("^[%d%.]+"))
    if not num then return nil end
    local suffix = text:match("^[%d%.]+%s*([A-Za-z]+)")
    return (suffix and SUFFIX[suffix]) and num * SUFFIX[suffix] or num
end

local function getMyPlot()
    local ok, data = pcall(function() return ReplicatedStorage.Remotes.GetPlotData:InvokeServer() end)
    if ok and data and data.plotId then
        return Workspace.Map.SpawnArea.Plots:FindFirstChild(tostring(data.plotId))
    end
    return nil
end

local function triggerUpgrade(plotFolder, floorName, placementIndex)
    local floor = plotFolder.Floors and plotFolder.Floors[floorName]
    if not floor then return false end
    local placement = floor.Functionals
        and floor.Functionals.BasePlacmentPlots
        and floor.Functionals.BasePlacmentPlots[tostring(placementIndex)]
    if not placement then return false end
    local upgradeBtn = placement.UpgradeButton
    if not upgradeBtn then return false end
    local cd = upgradeBtn:FindFirstChildOfClass("ClickDetector")
        or upgradeBtn:FindFirstChild("UpgradeClickDetector")
    if not cd then return false end
    return pcall(function() fireclickdetector(cd) end)
end

